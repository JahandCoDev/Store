// admin/prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  STAFF
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  AUTHORIZED
  PROCESSING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PrintJobStatus {
  QUEUED
  PRINTING
  DONE
  FAILED
}

enum ProjectType {
  WEBSITE
  MOBILE_APP
  CUSTOM_SOFTWARE
  MAINTENANCE
}

enum ProjectStatus {
  DISCOVERY
  DESIGN
  DEVELOPMENT
  TESTING
  DEPLOYED
  ON_HOLD
}

enum QuoteSubmissionStatus {
  NEW
  REVIEWED
  CONTACTED
  ARCHIVED
}

enum MediaAssetKind {
  IMAGE
  VIDEO
  DOCUMENT
}

// ─── Auth / Identity (NextAuth Standard) ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CUSTOMER)
  password      String?
  
  accounts      Account[]
  sessions      Session[]
  
  // E-commerce & CRM Relations
  orders        Order[]
  addresses     Address[]
  notes         CustomerNote[]
  
  // Agency Relations
  techProjects  TechProject[]
  quotes        QuoteSubmission[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── CRM / Customer Profiles ──────────────────────────────────────────────────

// Replaced your CustomerAddress with a unified Address model
model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  isDefault   Boolean  @default(false)
  type        String   @default("SHIPPING") // "SHIPPING" | "BILLING"
  
  firstName   String
  lastName    String
  company     String?
  line1       String
  line2       String?
  city        String
  state       String
  zip         String
  country     String   @default("US")
  phone       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model CustomerNote {
  id          String   @id @default(cuid())
  userId      String   // The customer this note is about
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdById String?  // The Staff/Admin who wrote the note
  body        String   @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ─── Catalog: Products, Variants, Collections ─────────────────────────────────

model Product {
  id              String          @id @default(cuid())
  handle          String          @unique
  title           String
  description     String          @db.Text @default("")
  status          ProductStatus   @default(DRAFT)
  vendor          String?
  tags            String[]        @default([])
  
  // Replaced complex Metafield tables with native JSONB
  metadata        Json?           @default("{}") 

  variants        ProductVariant[]
  options         ProductOption[]
  collections     CollectionProduct[]
  inventoryAdjs   InventoryAdjustment[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([handle])
}

model ProductOption {
  id          String        @id @default(cuid())
  productId   String
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String        // e.g., "Size", "Color"
  position    Int           @default(0)

  values      OptionValue[]

  @@unique([productId, name])
}

model OptionValue {
  id          String        @id @default(cuid())
  optionId    String
  option      ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  value       String        // e.g., "Large", "Red"
  
  variants    ProductVariant[] @relation("VariantToOptionValue")

  @@unique([optionId, value])
}

model ProductVariant {
  id              String    @id @default(cuid())
  productId       String
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  sku             String?   @unique
  barcode         String?
  title           String    // e.g., "Graphic Tee - Red / Large"
  
  price           Decimal   @db.Decimal(10, 2)
  compareAtPrice  Decimal?  @db.Decimal(10, 2)
  cost            Decimal?  @db.Decimal(10, 2)
  
  weight          Float?
  inventory       Int       @default(0)
  
  // Specific upcharges moved from Product to Variant metadata or specific fields
  backDesignUpcharge Decimal @default(0.00) @db.Decimal(10, 2)
  specialTextUpcharge Decimal @default(0.00) @db.Decimal(10, 2)

  optionValues    OptionValue[] @relation("VariantToOptionValue")
  orderItems      OrderItem[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([sku])
}

model Collection {
  id              String              @id @default(cuid())
  handle          String              @unique
  title           String
  description     String              @db.Text @default("")
  seoTitle        String?
  seoDescription  String?
  
  imageAssetId    String?
  imageAsset      MediaAsset?         @relation("CollectionImage", fields: [imageAssetId], references: [id], onDelete: SetNull)
  
  isPublished     Boolean             @default(false)
  sortOrder       Int                 @default(0)
  
  products        CollectionProduct[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([productId])
  @@index([collectionId, position])
}

model MediaAsset {
  id               String         @id @default(cuid())
  kind             MediaAssetKind @default(IMAGE)
  title            String?
  altText          String?
  originalFilename String
  mimeType         String
  storageKey       String         @unique
  sizeBytes        Int
  width            Int?
  height           Int?
  tags             String[]       @default([])
  
  collectionImages Collection[]   @relation("CollectionImage")
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ─── Inventory Management ─────────────────────────────────────────────────────

model InventoryAdjustment {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  delta       Int      // positive = restock, negative = shrinkage/write-off
  reason      String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([productId])
}

// ─── Orders & Checkout ────────────────────────────────────────────────────────

model Order {
  id             String      @id @default(cuid())
  orderNumber    Int         @unique @default(autoincrement())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  email          String
  currency       String      @default("USD")
  subtotal       Decimal     @db.Decimal(10, 2)
  taxAmount      Decimal     @db.Decimal(10, 2)
  shippingAmount Decimal     @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  
  status         OrderStatus @default(PENDING)
  note           String?     @db.Text

  // Snapshot of shipping info
  shippingName    String?
  shippingPhone   String?
  shippingLine1   String?
  shippingLine2   String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String?     @default("US")

  orderItems     OrderItem[]
  fulfillment    Fulfillment?

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
}

model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  
  title       String          // Snapshot e.g., "Tee - Red/Large"
  sku         String?
  quantity    Int
  price       Decimal         @db.Decimal(10, 2) // Price at checkout
}

model Fulfillment {
  id             String    @id @default(cuid())
  orderId        String    @unique
  order          Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  trackingNumber String?
  carrier        String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  notes          String?   @db.Text
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Printing / Workflow ──────────────────────────────────────────────────────

model PrintJob {
  id          String         @id @default(cuid())
  type        String         // SHIPPING_LABEL | INVOICE | PACKING_SLIP
  status      PrintJobStatus @default(QUEUED)
  assetUrl    String?        // URL to PDF/PNG
  printerName String?
  metadata    Json           @default("{}")
  errorText   String?        @db.Text
  reportedAt  DateTime?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ─── Digital Agency Services ──────────────────────────────────────────────────

model TechProject {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  
  title         String        // e.g., "E-commerce App Revamp"
  projectType   ProjectType 
  repositoryUrl String?       // Link to GitHub/GitLab repo
  productionUrl String?       // Link to live site/VPS
  
  status        ProjectStatus @default(DISCOVERY)
  milestones    Milestone[]   
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
}

model Milestone {
  id          String      @id @default(cuid())
  projectId   String
  project     TechProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title       String      // e.g., "UI/UX Figma Handoff"
  description String?     @db.Text
  amount      Decimal     @db.Decimal(10, 2)
  isPaid      Boolean     @default(false)
  dueDate     DateTime?
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([projectId])
}

model QuoteSubmission {
  id                     String                @id @default(cuid())
  userId                 String?
  user                   User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  name                   String
  email                  String
  phone                  String?
  selectedPlan           String?
  projectType            String
  budgetRange            String
  timeline               String
  addOns                 String[]              @default([])
  details                String                @db.Text
  status                 QuoteSubmissionStatus @default(NEW)
  
  adminNotifiedAt        DateTime?
  customerAcknowledgedAt DateTime?
  lastEmailError         String?               @db.Text

  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([userId])
  @@index([status])
}