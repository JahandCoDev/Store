#!/bin/bash
set -e

# ============================================================
# Async wrapper
# ============================================================
# This hook can take a long time (docker build/push + kubectl).
# By default we run it asynchronously so `git push` returns quickly.
# Set CI_HOOK_ASYNC=0 to keep the old synchronous behavior.

# Git push-options support:
#   - `git push -o follow`  => stream logs synchronously (old behavior)
#   - `git push -o async`   => force async background behavior
#   - `git push -o rebuild` => force rebuild/push of all images
#   - `git push -o k8s`     => force kubectl apply of k8s/ manifests
#   - default              => sync (streams logs to `git push`)
CI_HOOK_ASYNC=${CI_HOOK_ASYNC:-0}
CI_FORCE_BUILD=${CI_FORCE_BUILD:-0}
CI_FORCE_APPLY_K8S=${CI_FORCE_APPLY_K8S:-0}
if [ -n "${GIT_PUSH_OPTION_COUNT:-}" ]; then
    i=0
    while [ "$i" -lt "$GIT_PUSH_OPTION_COUNT" ]; do
        opt_var="GIT_PUSH_OPTION_$i"
        opt="${!opt_var:-}"
        if [ "$opt" = "follow" ] || [ "$opt" = "sync" ]; then
            CI_HOOK_ASYNC=0
        elif [ "$opt" = "async" ]; then
            CI_HOOK_ASYNC=1
        elif [ "$opt" = "rebuild" ] || [ "$opt" = "build-all" ]; then
            CI_FORCE_BUILD=1
        elif [ "$opt" = "k8s" ] || [ "$opt" = "apply-k8s" ]; then
            CI_FORCE_APPLY_K8S=1
        fi
        i=$((i + 1))
    done
fi
if [ "$CI_HOOK_ASYNC" = "1" ] && [ -z "${CI_HOOK_CHILD:-}" ]; then
    LOG_DIR="/home/deploy/ci_logs"
    mkdir -p "$LOG_DIR"

    TS=$(date +%Y%m%d-%H%M%S)
    RAND=${RANDOM:-0}
    INPUT_FILE=$(mktemp "/tmp/post-receive.${TS}.${RAND}.XXXX")
    cat > "$INPUT_FILE"

    LOG_FILE="$LOG_DIR/post-receive.${TS}.${RAND}.log"

    # Run the actual hook logic in a child process with the captured stdin.
    # Use a lock to avoid overlapping deploys when flock is available.
    (
        if command -v flock >/dev/null 2>&1; then
            exec 9>/home/deploy/.post-receive.lock
            flock 9
        fi
        export CI_HOOK_CHILD=1
        export CI_LOG_FILE="$LOG_FILE"
        bash "$0" < "$INPUT_FILE"
    ) > "$LOG_FILE" 2>&1 &

    echo ""
    echo "CI started in background. Logs: $LOG_FILE"
    echo "Tail with: ssh deploy@production-1 'tail -f $LOG_FILE'"
    exit 0
fi

# ============================================================
# Store вҖ” Directory-Aware CI/CD Post-Receive Hook
# Only builds & deploys components whose source files changed.
# ============================================================

TARGET_DIR="/home/deploy/store_build"
GIT_DIR="/home/deploy/store.git"
REGISTRY="registry.jahandco.dev"
NAMESPACE="ecom"

# Datadog CI Visibility + Logs (recommended: set these as env vars on the deploy host)
DD_API_KEY=${DD_API_KEY:-"00ffd211f63323c10acf562153b498e7"}
DD_SITE=${DD_SITE:-"api.us5.datadoghq.com"}
DD_PIPELINE_DASHBOARD_URL=${DD_PIPELINE_DASHBOARD_URL:-"https://admin.jahandco.dev/ci"}

# Optional: forward pipeline logs to your Admin app so they can be viewed at /ci.
# The endpoint should accept POSTs at: /api/ci/pipelines
CI_DASHBOARD_INGEST_URL=${CI_DASHBOARD_INGEST_URL:-""}
CI_DASHBOARD_TOKEN=${CI_DASHBOARD_TOKEN:-""}
CI_DASHBOARD_SHOP_ID=${CI_DASHBOARD_SHOP_ID:-"jahandco-shop"}

# Where logs are written on the deploy host (both sync + async modes).
LOG_DIR=${LOG_DIR:-"/home/deploy/ci_logs"}

# Optional: provide credentials so the hook can `docker login` before pushing.
# If not set, the hook assumes Docker is already logged in on the deploy host.
REGISTRY_USERNAME=${REGISTRY_USERNAME:-""}
REGISTRY_PASSWORD=${REGISTRY_PASSWORD:-""}

# Color codes for terminal output streamed back to `git push`
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m' # No Color

log()  { echo -e "${CYAN}[$1]${NC} $2"; }
ok()   { echo -e "${GREEN}вң… $1${NC}"; }
warn() { echo -e "${YELLOW}вҡ пёҸ  $1${NC}"; }
err()  { echo -e "${RED}вқҢ $1${NC}"; }
header() {
    echo ""
    echo -e "${BOLD}=================================================${NC}"
    echo -e "${BOLD}  $1${NC}"
    echo -e "${BOLD}=================================================${NC}"
}

ensure_docker_login() {
    if [ -n "$REGISTRY_USERNAME" ] && [ -n "$REGISTRY_PASSWORD" ]; then
        log "REGISTRY" "Logging into ${BOLD}$REGISTRY${NC} as ${BOLD}$REGISTRY_USERNAME${NC}..."
        echo "$REGISTRY_PASSWORD" | docker login "$REGISTRY" -u "$REGISTRY_USERNAME" --password-stdin
        ok "Docker login succeeded"
    else
        warn "REGISTRY_USERNAME/REGISTRY_PASSWORD not set; assuming Docker is already logged in"
    fi
}

ensure_log_capture() {
    mkdir -p "$LOG_DIR"

    if [ -z "${CI_LOG_FILE:-}" ]; then
        local ts rand
        ts=$(date +%Y%m%d-%H%M%S)
        rand=${RANDOM:-0}
        CI_LOG_FILE="$LOG_DIR/post-receive.${ts}.${rand}.log"
        export CI_LOG_FILE
    fi

    # In async mode, stdout/stderr are already redirected to the log file by the wrapper.
    # In sync mode, tee output so `git push` still streams logs while also persisting them.
    if [ "${CI_HOOK_ASYNC:-0}" = "0" ] && [ -z "${CI_HOOK_CHILD:-}" ] && [ -z "${CI_LOG_CAPTURED:-}" ]; then
        export CI_LOG_CAPTURED=1
        exec > >(tee -a "$CI_LOG_FILE") 2>&1
        echo ""
        echo "CI logs: $CI_LOG_FILE"
    fi
}

json_quote() {
    # Reads raw text from stdin and prints a valid JSON string literal (including surrounding quotes).
    if command -v python3 >/dev/null 2>&1; then
        python3 - <<'PY'
import json, sys
print(json.dumps(sys.stdin.read()))
PY
        return 0
    fi
    if command -v node >/dev/null 2>&1; then
        node - <<'NODE'
let data = '';
process.stdin.setEncoding('utf8');
process.stdin.on('data', c => data += c);
process.stdin.on('end', () => process.stdout.write(JSON.stringify(data)));
NODE
        return 0
    fi

    # Fallback: best-effort escaping (handles backslash, quote, and newlines).
    # This is sufficient for plain log output.
    sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' -e ':a;N;$!ba;s/\n/\\n/g' | awk '{print "\"" $0 "\""}'
}

# в”Җв”Җ Datadog CI Visibility (Optional) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
send_ci_event() {
    local final_status=$1
    if [ -z "$DD_API_KEY" ]; then return; fi

    local status_for_dd="$final_status"
    if [ "$final_status" = "error" ]; then status_for_dd="failed"; fi

    local end_time_json=""
    if [ "$final_status" != "running" ]; then
        local end_time=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        end_time_json="\"end\": \"$end_time\","
    fi

    local tmp_resp http_code
    tmp_resp=$(mktemp "/tmp/dd-ci.${PIPELINE_ID}.XXXX")
    http_code=$(curl -sS -o "$tmp_resp" -w "%{http_code}" -X POST "https://$DD_SITE/api/v2/ci/pipeline" \
        -H "Content-Type: application/json" \
        -H "DD-API-KEY: $DD_API_KEY" \
        -d @- <<EOF
{
  "data": {
    "attributes": {
        "resource": {
            "level": "pipeline",
            "unique_id": "$PIPELINE_ID",
            "name": "Ecom-CI",
            "git": {
                "repository_url": "ssh://production-1/home/deploy/store",
                "author_email": "$AUTHOR_EMAIL",
                "sha": "$FULL_SHA"
            },
            "status": "$status_for_dd",
            "start": "$START_TIME",
            $end_time_json
            "partial_retry": false,
            "url": "$DD_PIPELINE_DASHBOARD_URL"
        }
    },
    "type": "cipipeline_resource_request"
  }
}
EOF
)

    if [ "$http_code" -ge 400 ]; then
        warn "Datadog CI Visibility returned HTTP $http_code ($(head -c 300 "$tmp_resp" | tr '\n' ' '))"
    fi

    rm -f "$tmp_resp" || true
}

send_logs_to_dashboard() {
    local final_status=$1
    if [ -z "$CI_DASHBOARD_INGEST_URL" ] || [ -z "$CI_DASHBOARD_TOKEN" ]; then return; fi
    if [ -z "${CI_LOG_FILE:-}" ] || [ ! -f "$CI_LOG_FILE" ]; then return; fi

    local tmp_body tmp_resp http_code
    tmp_body=$(mktemp "/tmp/ci-dashboard.${PIPELINE_ID}.XXXX.json")
    tmp_resp=$(mktemp "/tmp/ci-dashboard.${PIPELINE_ID}.XXXX.resp")

    local log_tail log_json
    log_tail=$(tail -n 5000 "$CI_LOG_FILE" 2>/dev/null || cat "$CI_LOG_FILE")
    log_json=$(printf "%s" "$log_tail" | json_quote)

    cat > "$tmp_body" <<EOF
{
  "pipeline": {
    "unique_id": "$PIPELINE_ID",
    "name": "Ecom-CI",
    "git": {
      "repository_url": "ssh://production-1/home/deploy/store",
      "author_email": "$AUTHOR_EMAIL",
      "sha": "$FULL_SHA"
    },
    "status": "$final_status",
    "start": "$START_TIME",
    "end": "${END_TIME:-}",
    "partial_retry": false,
    "url": "$DD_PIPELINE_DASHBOARD_URL"
  },
    "log": $log_json
}
EOF

        http_code=$(curl -sS -o "$tmp_resp" -w "%{http_code}" -X POST "$CI_DASHBOARD_INGEST_URL" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $CI_DASHBOARD_TOKEN" \
        -H "X-Shop-Id: $CI_DASHBOARD_SHOP_ID" \
        -d @"$tmp_body" || true)

    if [ -n "$http_code" ] && [ "$http_code" -ge 400 ]; then
        warn "CI dashboard ingest returned HTTP $http_code ($(head -c 300 "$tmp_resp" | tr '\n' ' '))"
    fi

    rm -f "$tmp_body" "$tmp_resp" || true
}

send_logs_to_datadog() {
    local final_status=$1
    if [ -z "$DD_API_KEY" ]; then return; fi
    if [ -z "${CI_LOG_FILE:-}" ] || [ ! -f "$CI_LOG_FILE" ]; then return; fi

    local site_suffix logs_url tmp_body tmp_resp http_code
    site_suffix="${DD_SITE#api.}"
    logs_url="https://http-intake.logs.${site_suffix}/api/v2/logs"

    tmp_body=$(mktemp "/tmp/dd-logs.${PIPELINE_ID}.XXXX.json")
    tmp_resp=$(mktemp "/tmp/dd-logs.${PIPELINE_ID}.XXXX.resp")

    local log_tail log_json
    log_tail=$(tail -n 5000 "$CI_LOG_FILE" 2>/dev/null || cat "$CI_LOG_FILE")
    log_json=$(printf "%s" "$log_tail" | json_quote)

    cat > "$tmp_body" <<EOF
[
  {
    "ddsource": "bash",
    "service": "ecom-ci",
    "hostname": "production-1",
    "message": $log_json,
    "ddtags": "env:production-store,component:post-receive,pipeline_id:$PIPELINE_ID,commit:$COMMIT_HASH,status:$final_status"
  }
]
EOF

    http_code=$(curl -sS -o "$tmp_resp" -w "%{http_code}" -X POST "$logs_url" \
        -H "Content-Type: application/json" \
        -H "DD-API-KEY: $DD_API_KEY" \
        -d @"$tmp_body" || true)

    if [ -n "$http_code" ] && [ "$http_code" -ge 400 ]; then
        warn "Datadog Logs intake returned HTTP $http_code ($(head -c 300 "$tmp_resp" | tr '\n' ' '))"
    fi

    rm -f "$tmp_body" "$tmp_resp" || true
}

# в”Җв”Җ Build helper: docker build, tag, and push в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
build_and_push() {
    local name=$1
    local context=$2
    local extra_args=${3:-}

    log "BUILD" "рҹ“Ұ Building ${BOLD}$name${NC}..."
    docker build $extra_args \
        -t $REGISTRY/$name:$COMMIT_HASH \
        -t $REGISTRY/$name:latest \
        $context

    log "PUSH" "рҹҡў Pushing ${BOLD}$name:$COMMIT_HASH${NC}..."
    docker push $REGISTRY/$name:$COMMIT_HASH
    docker push $REGISTRY/$name:latest
    ok "$name built and pushed"
}

# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
# Main Hook Logic
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
while read oldrev newrev ref; do
    # Only trigger on pushes to main
    if [[ ! $ref =~ .*/main$ ]]; then
        warn "Push to $ref ignored (not main). Skipping."
        continue
    fi

    COMMIT_HASH=$(git rev-parse --short $newrev)
    FULL_SHA=$newrev
    AUTHOR_EMAIL=$(git --git-dir=$GIT_DIR log -1 --pretty=format:'%ae' $newrev)
    PIPELINE_ID="deploy-$(date +%s)-$COMMIT_HASH"
    START_TIME=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    ensure_log_capture

    # Trap errors to report failure to Datadog
    trap 'if [ $? -ne 0 ]; then err "Pipeline failed!"; echo -e "CI Dashboard: ${CYAN}https://admin.jahandco.dev/ci${NC}"; echo -e "Status: ${RED}FAILED${NC}"; END_TIME=$(date -u +"%Y-%m-%dT%H:%M:%SZ"); export END_TIME; send_ci_event "failed"; send_logs_to_dashboard "failed"; send_logs_to_datadog "failed"; fi' EXIT

    header "рҹҡҖ CI/CD Pipeline вҖ” Store Commit $COMMIT_HASH"

    send_ci_event "running"

    # в”Җв”Җ Detect changed directories в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if [ "$oldrev" = "0000000000000000000000000000000000000000" ]; then
        CHANGED_FILES=$(git --git-dir=$GIT_DIR diff-tree --no-commit-id --name-only -r $newrev)
    else
        CHANGED_FILES=$(git --git-dir=$GIT_DIR diff --name-only $oldrev $newrev)
    fi

    BUILD_STOREFRONT=false
    BUILD_ADMIN=false
    BUILD_TELEPHONY=false
    APPLY_K8S=false

    echo "$CHANGED_FILES" | grep -q "^storefront/"       && BUILD_STOREFRONT=true   || true
    echo "$CHANGED_FILES" | grep -q "^admin/"            && BUILD_ADMIN=true        || true
    echo "$CHANGED_FILES" | grep -q "^telephony/"        && BUILD_TELEPHONY=true    || true
    echo "$CHANGED_FILES" | grep -q "^k8s/"              && APPLY_K8S=true          || true

    if [ "$CI_FORCE_BUILD" = "1" ]; then
        warn "Force rebuild enabled via git push-option; building all components"
        BUILD_STOREFRONT=true
        BUILD_ADMIN=true
        BUILD_TELEPHONY=true
    fi

    if [ "$CI_FORCE_APPLY_K8S" = "1" ]; then
        warn "Force k8s apply enabled via git push-option"
        APPLY_K8S=true
    fi

    # If nothing relevant changed, skip
    if ! $BUILD_STOREFRONT && ! $BUILD_ADMIN && ! $BUILD_TELEPHONY && ! $APPLY_K8S; then
        warn "No watched directories changed. Skipping build."
        ok "Pipeline complete (no-op)"
        echo -e "CI Dashboard: ${CYAN}https://admin.jahandco.dev/ci${NC}"
        echo -e "Status: ${GREEN}SUCCESS (No-op)${NC}"
        END_TIME=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        export END_TIME
        send_ci_event "success"
        send_logs_to_dashboard "success"
        send_logs_to_datadog "success"
        trap - EXIT
        continue
    fi

    # в”Җв”Җ Checkout latest code в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    log "GIT" "Checking out main to $TARGET_DIR..."
    mkdir -p $TARGET_DIR
    git --work-tree=$TARGET_DIR --git-dir=$GIT_DIR checkout -f main

    cd $TARGET_DIR

    # в”Җв”Җ Registry auth (for pushing images) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    ensure_docker_login

    # в”Җв”Җ Summary of what will be built в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    echo ""
    log "PLAN" "Components to build:"
    $BUILD_STOREFRONT  && log "PLAN" "  вҖў Storefront      (storefront changed)"
    $BUILD_ADMIN       && log "PLAN" "  вҖў Admin           (admin changed)"
    $BUILD_TELEPHONY   && log "PLAN" "  вҖў Telephony       (telephony changed)"
    $APPLY_K8S         && log "PLAN" "  вҖў K8s Manifests   (k8s/ changed)"
    echo ""

    # в”Җв”Җ Conditional Builds в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if $BUILD_STOREFRONT; then
        build_and_push "store/storefront" "./storefront"
    fi

    if $BUILD_ADMIN; then
        build_and_push "store/admin" "./admin"
    fi

    if $BUILD_TELEPHONY; then
        build_and_push "store/telephony" "./telephony"
    fi

    # в”Җв”Җ Apply K8s Manifests (if k8s/ changed) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if $APPLY_K8S; then
        log "K8S" "вҳёпёҸ  Applying Kubernetes manifests..."
        export KUBECONFIG=~/.kube/config

        for manifest in $TARGET_DIR/k8s/*.yaml; do
            log "K8S" "  Applying $(basename $manifest)..."
            kubectl --insecure-skip-tls-verify=true apply -f $manifest 2>&1 || true
        done
        ok "K8s manifests applied"
    fi

    # в”Җв”Җ Rolling Updates (only for built images) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    log "K8S" "вҳёпёҸ  Triggering rolling updates for changed components..."
    export KUBECONFIG=~/.kube/config

    if $BUILD_STOREFRONT; then
        kubectl --insecure-skip-tls-verify=true set image deployment/storefront \
            storefront=$REGISTRY/store/storefront:$COMMIT_HASH \
            -n $NAMESPACE 2>&1 || warn "Storefront deployment not found, skipping rollout"
    fi

    if $BUILD_ADMIN; then
        kubectl --insecure-skip-tls-verify=true set image deployment/admin \
            admin=$REGISTRY/store/admin:$COMMIT_HASH \
            -n $NAMESPACE 2>&1 || warn "Admin deployment not found, skipping rollout"
    fi

    if $BUILD_TELEPHONY; then
        kubectl --insecure-skip-tls-verify=true set image deployment/telephony \
            telephony=$REGISTRY/store/telephony:$COMMIT_HASH \
            -n $NAMESPACE 2>&1 || warn "telephony deployment not found, skipping rollout"
    fi

    # в”Җв”Җ Cleanup в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    log "CLEAN" "рҹ§№ Pruning dangling docker images..."
    docker image prune -f > /dev/null 2>&1

    header "вң… Pipeline Complete вҖ” $COMMIT_HASH"
    echo -e "CI Dashboard: ${CYAN}https://admin.jahandco.dev/ci${NC}"
    echo -e "Status: ${GREEN}SUCCESS${NC}"
    END_TIME=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    export END_TIME
    send_ci_event "success"
    send_logs_to_dashboard "success"
    send_logs_to_datadog "success"
    trap - EXIT
done
